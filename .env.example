# ══ Credenciales de Meta / WhatsApp Business API ══
# Copia este archivo como .env y rellena con tus datos reales
# NUNCA subas el archivo .env real a GitHub — solo este .env.example

# Phone Number ID que te dio Meta (Paso 1 o Paso 2 del dashboard)
WHATSAPP_PHONE_NUMBER_ID=tu_phone_number_id_aqui

# Token de acceso — al principio es el temporal (24h), luego será el permanente
WHATSAPP_TOKEN=tu_token_de_acceso_aqui

# Verify Token — lo inventas tú mismo, cualquier palabra secreta
# Debe coincidir EXACTO con lo que pongas en el dashboard de Meta al configurar el Webhook
WEBHOOK_VERIFY_TOKEN=central_webhook_secreto_123

# Puerto del servidor (Railway lo asigna automático, no lo toques en producción)
PORT=3000

# ID de tu app de Meta (para referencia, no siempre se usa en llamadas)
META_APP_ID=986144690698838
